# Environment-specific configuration files

NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/identity_forge

# JWT
JWT_SECRET=dev-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRY=15m

# Redis
REDIS_URL=redis://:redis_password@localhost:6379

# Email (use MailHog or similar)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=user
SMTP_PASS=password
SMTP_FROM=noreply@localhost

# SMS (use Twilio test credentials)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-test-auth-token
TWILIO_PHONE_NUMBER=+15005550006

# Captcha (use test keys)
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Session
SESSION_SECRET=dev-session-secret-key-at-least-32-characters-long

# Logging
LOG_LEVEL=debug
