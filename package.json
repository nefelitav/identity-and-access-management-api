{
  "name": "auth-forge-api",
  "private": true,
  "_moduleAliases": {
    "~": "dist/apps/api"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "tsc --noEmit",
    "test": "jest --config jest.config.js --runInBand --passWithNoTests",
    "test:coverage": "jest --config jest.config.js --coverage --passWithNoTests",
    "docs": "typedoc --entryPointStrategy expand --out docs apps --tsconfig apps/api/tsconfig.json",
    "prepare": "husky",
    "docker:build": "docker build -t identity-forge-api .",
    "docker:run": "docker run -p 3000:3000 identity-forge-api",
    "docker:dev": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "yarn prisma migrate deploy --schema=./packages/prisma/prisma/schema.prisma",
    "db:generate": "yarn prisma generate --schema=./packages/prisma/prisma/schema.prisma",
    "db:studio": "yarn prisma studio --schema=./packages/prisma/prisma/schema.prisma",
    "db:reset": "yarn prisma migrate reset --schema=./packages/prisma/prisma/schema.prisma",
    "security:audit": "yarn audit --level moderate",
    "security:scan": "trivy fs ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --cache --fix"
    ],
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "prisma": "^6.11.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typedoc": "^0.28.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^6.11.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "envalid": "^8.0.0",
    "express": "^5.2.0",
    "express-rate-limit": "^7.5.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "nodemailer": "^7.0.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "redis": "^5.0.1",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.6.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "resolutions": {
    "validator": ">=13.15.20"
  }
}
